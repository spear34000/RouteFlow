{
  "name": "@routeflow/adapter-postgres",
  "version": "0.0.1",
  "description": "PostgreSQL adapter for RouteFlow — LISTEN/NOTIFY based change streaming",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@routeflow/core": "workspace:*",
    "pg": "^8.13.3"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/pg": "^8.11.10",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}

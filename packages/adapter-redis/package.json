{
  "name": "@spear340000/adapter-redis",
  "version": "0.1.0",
  "description": "Redis adapter for RouteFlow — pub/sub based change streaming",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/spear34000/RouteFlow.git"
  },
  "homepage": "https://github.com/spear34000/RouteFlow#readme",
  "bugs": {
    "url": "https://github.com/spear34000/RouteFlow/issues"
  },
  "keywords": [
    "routeflow",
    "redis",
    "realtime",
    "pubsub"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "dev": "tsup --watch"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@spear340000/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}

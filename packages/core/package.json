{
  "name": "@spear340000/core",
  "version": "0.1.0",
  "description": "RouteFlow core framework — REST + real-time DB push",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/spear34000/RouteFlow.git"
  },
  "homepage": "https://github.com/spear34000/RouteFlow#readme",
  "bugs": {
    "url": "https://github.com/spear34000/RouteFlow/issues"
  },
  "keywords": [
    "routeflow",
    "rest",
    "realtime",
    "websocket",
    "sse",
    "typescript"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./adapters": {
      "types": "./dist/adapter/index.d.ts",
      "import": "./dist/adapter/index.mjs",
      "require": "./dist/adapter/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "dev": "tsup --watch"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "fastify": "^4.28.0",
    "reflect-metadata": "^0.2.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.13",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}

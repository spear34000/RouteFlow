{
  "name": "@routeflow/adapter-postgres",
  "version": "0.1.0",
  "description": "PostgreSQL adapter for RouteFlow — LISTEN/NOTIFY based change streaming",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/spear34000/RouteFlow.git"
  },
  "homepage": "https://github.com/spear34000/RouteFlow#readme",
  "bugs": {
    "url": "https://github.com/spear34000/RouteFlow/issues"
  },
  "keywords": [
    "routeflow",
    "postgres",
    "postgresql",
    "realtime",
    "cdc"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "dev": "tsup --watch"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@routeflow/core": "workspace:*",
    "pg": "^8.13.3"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/pg": "^8.11.10",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
